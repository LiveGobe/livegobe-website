# LSP Server Configuration

# Server
NODE_ENV=development
LSP_PORT=8081
LSP_HOST=localhost
LSP_WORKERS=1

# Wiki API
WIKI_API_BASE=http://localhost:8080/api
WIKI_API_VERSION=2
WIKI_API_TIMEOUT=5000

# Cache
CACHE_STRATEGY=multi-level
CACHE_TTL_MODULES=300000
CACHE_TTL_API=600000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Tern.js
TERN_ECMA_VERSION=6
